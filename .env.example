# ============================================================================
# CRITICAL FOR PRODUCTION DEPLOYMENT
# ============================================================================

# Django Secret Key
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
# NEVER use default value in production
SECRET_KEY=your-secret-key-here-GENERATE-NEW-FOR-PRODUCTION

# PostgreSQL Connection String (REQUIRED for Vercel deployment)
# Format: postgresql://user:password@host:port/database
# From Supabase: https://supabase.com
# CRITICAL: Replace [PASSWORD] with your actual database password
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# Gemini API Key (for AI career pathway generation)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-google-gemini-api-key

# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# Debug Mode
# Set to False for production (Vercel)
DEBUG=False

# Django Settings Module
DJANGO_SETTINGS_MODULE=saarthi.settings

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,cep-2026-ivory.vercel.app,*.vercel.app

# CORS Origins (for API access)
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8000,http://localhost:8080,https://cep-2026-ivory.vercel.app

# Backend API URL
# Development: http://localhost:5000/api
# Production: https://cep-2026-ivory.vercel.app/api
BACKEND_API_URL=https://cep-2026-ivory.vercel.app/api

# ============================================================================
# ADMIN CREDENTIALS (for create_admin.py script)
# ============================================================================

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# ============================================================================
# NODE.JS SERVER (Optional)
# ============================================================================

NODE_ENV=production
PORT=5000

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. LOCAL DEVELOPMENT:
#    - Copy .env.example → .env
#    - Set DEBUG=True
#    - Use SQLite: DATABASE_URL not needed (defaults to db.sqlite3)
#    - Add API keys
#
# 2. PRODUCTION DEPLOYMENT:
#    - Set DEBUG=False
#    - Set DATABASE_URL to Supabase PostgreSQL connection string
#    - Generate new SECRET_KEY via python command above
#    - Add all required API keys
#    - Set ALLOWED_HOSTS for your domain
#    - Add environment variables to Vercel dashboard
#
# 3. SECURITY:
#    - Never commit .env to Git
#    - Add .env to .gitignore
#    - Use different SECRET_KEY for each environment
#    - Rotate API keys regularly
#
# ============================================================================


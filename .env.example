# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Database (PostgreSQL for production, SQLite for development)
# Development (local):
# DATABASE_URL=sqlite:///./db.sqlite3

# Production (Vercel - PostgreSQL from Supabase/Neon/Railway):
DATABASE_URL=postgresql://user:password@host:port/database

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,cep-2026-ivory.vercel.app,*.vercel.app

# CORS Origins
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8000,http://localhost:8080,https://cep-2026-ivory.vercel.app

# Backend API URL
BACKEND_API_URL=https://cep-2026-ivory.vercel.app/api

# Google Generative AI (Gemini API)
GOOGLE_API_KEY=your-google-gemini-api-key

# Admin Credentials (for create_admin.py script)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Node.js Server
NODE_ENV=production
PORT=5000

